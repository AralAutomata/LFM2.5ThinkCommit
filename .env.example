# ThinkCommit Environment Configuration
# Copy this file to .env and adjust as needed

# Ollama API endpoint
# For Docker with host Ollama (distrobox): http://host.docker.internal:11434
# For local development without Docker: http://localhost:11434
# For Docker with Ollama container: http://ollama:11434
OLLAMA_HOST=http://host.docker.internal:11434

# Model to use for thinking/response generation
# Must be lfm2.5-thinking for the commitment scheme to work
OLLAMA_MODEL=lfm2.5-thinking

# Temperature for model inference (0.0-1.0)
# Lower = more deterministic, higher = more creative
# Recommended: 0.1 for consistent commitments
OLLAMA_TEMPERATURE=0.1

# Paths (relative to container /app directory)
KEYS_DIR=/app/keys
RECORDS_DIR=/app/records
